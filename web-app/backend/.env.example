# Server
PORT=5000
NODE_ENV=development

# Database (PostgreSQL)
DB_DIALECT=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=careerlens
DB_USER=postgres
DB_PASSWORD=password

# AI Service
# --- AI Service Integration ---
# URL of the Hugging Face AI Inference API
AI_SERVICE_URL=https://shusiee-careerlens-api.hf.space
# Timeout for AI requests in milliseconds (120000 = 120 seconds for cold starts)
AI_SERVICE_TIMEOUT=120000

# CORS
CORS_ORIGIN=http://localhost:3000

# SMTP Settings (Untuk pengiriman email PDF)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
# Ganti dengan email asli Anda (contoh: budi@gmail.com)
SMTP_USER=alamat.email.kamu@gmail.com
# Ganti dengan 16-digit App Password dari akun Google Anda, BUKAN password login biasa
SMTP_PASSWORD=app-password-ini
EMAIL_FROM=alamat.email.kamu@gmail.com
EMAIL_REPLY_TO=alamat.email.kamu@gmail.com